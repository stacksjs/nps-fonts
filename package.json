{
  "name": "@nps-fonts/monorepo",
  "version": "0.7.0",
  "private": true,
  "description": "Original open-source typefaces inspired by U.S. National Park Service signage — drawn from scratch",
  "license": "OFL-1.1",
  "homepage": "https://github.com/stacksjs/nps-fonts",
  "repository": {
    "type": "git",
    "url": "https://github.com/stacksjs/nps-fonts.git"
  },
  "bugs": {
    "url": "https://github.com/stacksjs/nps-fonts/issues"
  },
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "bun run scripts/build.ts --all",
    "build:fonts": "bun run scripts/build.ts --all",
    "build:family": "bun run scripts/build.ts --family",
    "webfonts": "bun run scripts/webfonts.ts",
    "specimen": "bun run scripts/specimen.ts",
    "web": "bun run scripts/web.ts",
    "web:dev": "bun run scripts/web.ts --serve",
    "review": "bun run scripts/review.ts",
    "check": "bun run scripts/check.ts",
    "lint": "bunx --bun pickier lint . --max-warnings 9999 || true",
    "typecheck": "bunx --bun tsc --noEmit",
    "clean": "rm -rf fonts/**/{otf,ttf,woff,woff2,variable}/*.* web/dist specimens/*.pdf packages/*/dist",
    "release": "bun run build && bun run web && bun run pack:all",
    "pack:all": "bun run scripts/pack.ts",
    "test": "bun test",
    "verify": "bun run scripts/_verify-exact.ts"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/opentype.js": "^1.3.8",
    "pngjs": "^7.0.0",
    "typescript": "^5.6.0"
  },
  "dependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "opentype.js": "^1.3.4",
    "ts-font-editor": "link:ts-font-editor",
    "wawoff2": "^2.0.1"
  },
  "engines": {
    "bun": ">=1.1.0",
    "node": ">=20"
  }
}
